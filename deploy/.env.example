# MeshVPN Server Configuration

# Server settings
SERVER_DOMAIN=your-domain.ru
EXTERNAL_IP=YOUR_SERVER_PUBLIC_IP

# Database
DB_PATH=./data/meshvpn.db

# Ports
HTTP_PORT=8080
STUN_PORT=3478
TURN_PORT=5349

# TURN credentials (измените в продакшене!)
TURN_USER=meshvpn
TURN_SECRET=change_this_secret_key

# Optional: Let's Encrypt email для HTTPS
ACME_EMAIL=your-email@example.com

# Debug mode
DEBUG=false
